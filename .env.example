# Copy this file to `.env` and fill in real values for your environment.
# Never commit a real `.env` file.

# --- App ---
APP_ENV=dev                       # dev | staging | prod — controls log rendering (console vs JSON)
LOG_LEVEL=INFO                    # standard logging level name

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string   # HMAC signing secret for JWTs
JWT_ALGORITHM=HS256                            # JWT signing algorithm
JWT_EXPIRY_MINUTES=720                         # access token lifetime in minutes

# --- Postgres ---
PG_DSN=postgresql+asyncpg://botree:botree@localhost:5432/botree_chat   # async SQLAlchemy DSN

# --- LLM ---
LLM_PROVIDER=anthropic            # anthropic | cloudflare

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx   # Anthropic API key
ANTHROPIC_MODEL_SQL=claude-sonnet-5                     # model used for NL->SQL generation
ANTHROPIC_MODEL_SMALL=claude-haiku-4-5                  # model used for lightweight/small tasks

# --- Cloudflare ---
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id        # Cloudflare Workers AI account id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token          # Cloudflare Workers AI API token
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct         # Cloudflare Workers AI model id

# --- MySQL Analytics ---
MYSQL_HOST=127.0.0.1               # analytics MySQL host
MYSQL_PORT=3306                    # analytics MySQL port
MYSQL_USER=analytics_user          # analytics MySQL user
MYSQL_PASSWORD=change-me           # analytics MySQL password
MYSQL_DATABASE=analytics_db        # analytics MySQL database name
MYSQL_QUERY_TIMEOUT_S=15           # max seconds a generated analytics query may run

# --- SSH Tunnel ---
SSH_TUNNEL_ENABLED=false           # true to tunnel MySQL connections through an SSH bastion
SSH_HOST=bastion.example.com       # SSH bastion host
SSH_PORT=22                        # SSH bastion port
SSH_USER=deploy                    # SSH bastion user
SSH_KEY_PATH=/path/to/id_rsa       # path to the SSH private key
SSH_KEY_PASSWORD=                  # passphrase for the SSH private key, if any

# --- Cache ---
SEMANTIC_THRESHOLD=0.92            # cosine similarity threshold for semantic cache hits
RESULT_CACHE_TTL_S=300             # seconds a cached query result stays valid
SQL_ROW_CAP=50                    # max rows returned by any generated SQL query
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5   # sentence-transformers model used for embeddings

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]   # JSON list of allowed CORS origins

# --- SQL Safety ---
REQUIRE_SQL_APPROVAL=false         # true to require human approval before executing generated SQL
